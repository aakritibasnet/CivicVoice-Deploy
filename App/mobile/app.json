{
  "expo": {
    "name": "CivicVoice",
    "slug": "civicvoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": false
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.civicvoice.mobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "android": {
            "backgroundColor": "#ffffff",
            "resizeMode": "contain",
            "drawable": {
              "icon": "./assets/splashscreen_logo.xml"
            },
            "dark": {
              "backgroundColor": "#000000"
            }
          },
          "ios": {
            "backgroundColor": "#ffffff",
            "dark": {
              "backgroundColor": "#000000"
            }
          }
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "392136a5-ca24-4259-a49e-03b391c4ccd5"
      }
    }
  }
}
