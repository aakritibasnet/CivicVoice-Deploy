generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String?  @db.Uuid
  actor_id   String?  @db.Uuid
  actor_name String?  @db.VarChar(255)
  action     String   @db.VarChar(100)
  details    Json?    @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users?   @relation(fields: [actor_id], references: [id], onUpdate: NoAction)
  reports    reports? @relation(fields: [report_id], references: [id], onUpdate: NoAction)

  @@index([actor_id], map: "idx_activity_log_actor")
  @@index([created_at(sort: Desc)], map: "idx_activity_log_created")
  @@index([report_id], map: "idx_activity_log_report")
}

model analytics_snapshots {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshot_date DateTime @db.Date
  metrics       Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([snapshot_date], map: "idx_analytics_date")
}

model ward_happiness_events {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_key      String   @unique @db.VarChar(255)
  ward_id        String   @db.Uuid
  report_id      String?  @db.Uuid
  event_type     String   @db.VarChar(80)
  penalty_points Int      @default(0)
  details        Json?    @default("{}")
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  reports        reports? @relation(fields: [report_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  wards          wards    @relation(fields: [ward_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_type], map: "idx_ward_happiness_events_type")
  @@index([report_id], map: "idx_ward_happiness_events_report")
  @@index([ward_id, created_at(sort: Desc)], map: "idx_ward_happiness_events_ward_created")
}

model anonymous_report_claims {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String   @db.Uuid
  device_id  String   @db.VarChar(255)
  claimed_by String   @db.Uuid
  claimed_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [claimed_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model anonymous_reports {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String   @db.Uuid
  device_id  String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([report_id, device_id])
  @@index([device_id], map: "idx_anonymous_reports_device")
}

model attachments {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id   String   @db.Uuid
  filename    String   @db.VarChar(500)
  url         String   @db.VarChar(1000)
  mime_type   String?  @db.VarChar(100)
  size_bytes  BigInt?
  stage       String   @default("submission") @db.VarChar(50)
  uploaded_by String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  reports     reports  @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?   @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([report_id], map: "idx_attachments_report")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model badges {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String        @unique @db.VarChar(100)
  description    String
  icon_name      String        @default("ribbon-outline") @db.VarChar(100)
  tier           String        @default("bronze") @db.VarChar(20)
  criteria_type  String        @db.VarChar(50)
  criteria_value Int           @default(1)
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  user_badges    user_badges[]
}

model bookmarks {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String    @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  reports    reports   @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([report_id, user_id])
  @@index([report_id], map: "idx_bookmarks_report_id")
  @@index([user_id], map: "idx_bookmarks_user_id")
}

model comments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String    @db.Uuid
  user_id    String?   @db.Uuid
  content    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  reports    reports   @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_comments_created_at")
  @@index([report_id], map: "idx_comments_report_id")
  @@index([user_id], map: "idx_comments_user_id")
}

model task_completions {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id                 String        @unique @db.Uuid
  completed_by_user_id    String?       @db.Uuid
  completed_by_officer_id String?       @db.Uuid
  description             String?
  before_image_url        String?       @db.VarChar(2048)
  after_image_url         String        @db.VarChar(2048)
  completed_at            DateTime      @default(now()) @db.Timestamptz(6)
  created_at              DateTime      @default(now()) @db.Timestamptz(6)
  updated_at              DateTime      @default(now()) @db.Timestamptz(6)
  reports                 reports       @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  completed_by_user       users?        @relation("task_completions_completed_by_user", fields: [completed_by_user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  completed_by_officer    officers?     @relation(fields: [completed_by_officer_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  report_posts            report_posts?

  @@index([completed_at(sort: Desc)], map: "idx_task_completions_completed_at")
  @@index([completed_by_user_id], map: "idx_task_completions_completed_by_user")
  @@index([completed_by_officer_id], map: "idx_task_completions_completed_by_officer")
}

model report_posts {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id                    String                  @unique @db.Uuid
  completion_id              String                  @unique @db.Uuid
  ward_id                    String?                 @db.Uuid
  source_user_id             String?                 @db.Uuid
  title                      String                  @db.VarChar(500)
  description                String?
  category                   String                  @db.VarChar(100)
  priority                   priority_level          @default(medium)
  before_image_url           String?                 @db.VarChar(2048)
  after_image_url            String                  @db.VarChar(2048)
  ward_name_snapshot         String                  @db.VarChar(255)
  completed_by_name_snapshot String                  @db.VarChar(255)
  completed_by_role_snapshot String                  @db.VarChar(50)
  task_snapshot              Json                    @default("{}")
  completion_snapshot        Json                    @default("{}")
  rating_average             Float                   @default(0)
  rating_count               Int                     @default(0)
  comment_count              Int                     @default(0)
  bookmark_count             Int                     @default(0)
  edited_count               Int                     @default(0)
  completed_at               DateTime                @db.Timestamptz(6)
  created_at                 DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                @default(now()) @db.Timestamptz(6)
  reports                    reports                 @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  task_completions           task_completions        @relation(fields: [completion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wards                      wards?                  @relation(fields: [ward_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  source_user                users?                  @relation("report_posts_source_user", fields: [source_user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  report_ratings             report_ratings[]
  report_comments            report_comments[]
  report_post_bookmarks      report_post_bookmarks[]

  @@index([ward_id], map: "idx_report_posts_ward")
  @@index([created_at(sort: Desc)], map: "idx_report_posts_created")
  @@index([rating_average(sort: Desc)], map: "idx_report_posts_rating_average")
  @@index([source_user_id], map: "idx_report_posts_source_user")
}

model report_ratings {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id      String       @db.Uuid
  user_id      String       @db.Uuid
  rating       Int
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  report_posts report_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users        @relation("report_ratings_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([post_id, user_id])
  @@index([post_id], map: "idx_report_ratings_post")
  @@index([user_id], map: "idx_report_ratings_user")
}

model report_comments {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id                String                   @db.Uuid
  user_id                String                   @db.Uuid
  parent_id              String?                  @db.Uuid
  content                String
  anonymous_name         String                   @db.VarChar(80)
  reply_count            Int                      @default(0)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  report_posts           report_posts             @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  users                    @relation("report_comments_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent                 report_comments?         @relation("report_comment_replies", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies                report_comments[]        @relation("report_comment_replies")
  report_comment_reports report_comment_reports[]

  @@index([post_id, created_at(sort: Asc)], map: "idx_report_comments_post_created")
  @@index([parent_id], map: "idx_report_comments_parent")
  @@index([user_id], map: "idx_report_comments_user")
}

model report_comment_reports {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  comment_id      String          @db.Uuid
  user_id         String          @db.Uuid
  reason          String
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  report_comments report_comments @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users           @relation("report_comment_reports_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comment_id, user_id])
  @@index([comment_id], map: "idx_report_comment_reports_comment")
  @@index([user_id], map: "idx_report_comment_reports_user")
}

model report_post_bookmarks {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id      String       @db.Uuid
  user_id      String       @db.Uuid
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  report_posts report_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users        @relation("report_post_bookmarks_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([post_id, user_id])
  @@index([post_id], map: "idx_report_post_bookmarks_post")
  @@index([user_id], map: "idx_report_post_bookmarks_user")
}

model kanban_columns {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String        @db.VarChar(100)
  position      Int           @default(0)
  color         String        @default("#6b7280") @db.VarChar(20)
  deadline_days Int?
  is_terminal   Boolean       @default(false)
  mapped_status report_status @default(incoming)
  is_default    Boolean       @default(false)
  role_access   user_role[]   @default([])
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  reports       reports[]

  @@index([is_default], map: "idx_kanban_columns_is_default")
  @@index([role_access], map: "idx_kanban_columns_role_access")
}

model notification_preferences {
  user_id                  String   @id @db.Uuid
  notify_status_changes    Boolean  @default(true)
  notify_comments          Boolean  @default(true)
  notify_upvote_milestones Boolean  @default(true)
  notify_badge_earned      Boolean  @default(true)
  notify_nearby_resolved   Boolean  @default(false)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
  users                    users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model kanban_user_preferences {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  collapsed_columns Json     @default("[]")
  column_order      Json?
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id])
  @@index([user_id], map: "idx_kanban_prefs_user")
}

model notifications {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  report_id  String?  @db.Uuid
  title      String   @db.VarChar(255)
  message    String
  type       String   @default("info") @db.VarChar(50)
  link       String?  @db.VarChar(500)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reports    reports? @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_user")
  @@index([user_id, is_read], map: "idx_notifications_user_unread")
  @@index([report_id], map: "idx_notifications_report")
}

model report_followers {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([report_id, user_id])
  @@index([report_id], map: "idx_report_followers_report")
  @@index([user_id], map: "idx_report_followers_user")
}

model push_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @db.VarChar(255)
  platform   String   @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, token])
  @@index([user_id], map: "idx_push_tokens_user")
}

model password_reset_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_password_reset_user")
}

model pending_users {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  role          String   @default("citizen") @db.VarChar(50)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([email], map: "idx_pending_users_email")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_refresh_tokens_expires")
  @@index([token_hash], map: "idx_refresh_tokens_hash")
  @@index([user_id], map: "idx_refresh_tokens_user")
}

model officer_refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  officer_id String    @db.Uuid
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  officers   officers  @relation(fields: [officer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_officer_refresh_tokens_expires")
  @@index([token_hash], map: "idx_officer_refresh_tokens_hash")
  @@index([officer_id], map: "idx_officer_refresh_tokens_officer")
}

model reports {
  id                                                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                                                      String                    @db.VarChar(500)
  description                                                String?
  category                                                   String                    @db.VarChar(100)
  subcategory                                                String?                   @db.VarChar(100)
  location_lat                                               Float?
  location_lng                                               Float?
  address_text                                               String?
  citizen_name                                               String?                   @db.VarChar(255)
  citizen_contact                                            String?                   @db.VarChar(255)
  submitted_at                                               DateTime                  @default(now()) @db.Timestamptz(6)
  photo_urls                                                 Json?                     @default("[]")
  ward_id                                                    String?                   @db.Uuid
  ward_officer_id                                            String?                   @db.Uuid
  ward_work_attempted                                        String?
  ward_notes                                                 String?
  ward_received_at                                           DateTime?                 @db.Timestamptz(6)
  incoming_seen_at                                           DateTime?                 @db.Timestamptz(6)
  incoming_ack_deadline_at                                   DateTime?                 @db.Timestamptz(6)
  ward_active_started_at                                     DateTime?                 @db.Timestamptz(6)
  ward_deadline_at                                           DateTime?                 @db.Timestamptz(6)
  ward_deadline_reason                                       String?
  pathway_type                                               pathway_type?
  pathway_reason                                             String?
  days_overdue                                               Int?
  forwarding_officer_id                                      String?                   @db.Uuid
  pathway_timestamp                                          DateTime                  @default(now()) @db.Timestamptz(6)
  kanban_column_id                                           String?                   @db.Uuid
  assigned_officer_id                                        String?                   @db.Uuid
  assigned_department_id                                     String?                   @db.Uuid
  assigned_field_officer_id                                  String?                   @db.Uuid
  municipality_notes                                         String?
  priority                                                   priority_level            @default(medium)
  estimated_completion_date                                  DateTime?                 @db.Date
  actual_completion_date                                     DateTime?                 @db.Date
  resolution_description                                     String?
  resolution_photo_urls                                      Json?                     @default("[]")
  resolution_document_urls                                   Json?                     @default("[]")
  return_reasoning                                           String?
  return_instructions                                        String?
  assigned_level                                             assignment_level          @default(ward)
  escalated_to_municipality                                  Boolean                   @default(false)
  escalated_at                                               DateTime?                 @db.Timestamptz(6)
  escalation_type                                            String?                   @db.VarChar(80)
  escalation_source                                          String?                   @db.VarChar(80)
  returned_to_ward_at                                        DateTime?                 @db.Timestamptz(6)
  status                                                     report_status             @default(incoming)
  status_history                                             Json?                     @default("[]")
  municipality_received_at                                   DateTime                  @default(now()) @db.Timestamptz(6)
  municipality_deadline_at                                   DateTime?                 @db.Timestamptz(6)
  created_at                                                 DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                                                 DateTime                  @default(now()) @db.Timestamptz(6)
  user_id                                                    String?                   @db.Uuid
  is_public                                                  Boolean                   @default(true)
  media_url                                                  String?
  media_public_id                                            String?                   @db.VarChar(255)
  media_type                                                 String?                   @default("photo") @db.VarChar(20)
  location_accuracy_m                                        Float?
  upvote_count                                               Int                       @default(0)
  comment_count                                              Int                       @default(0)
  device_id                                                  String?                   @db.VarChar(255)
  activity_log                                               activity_log[]
  anonymous_report_claims                                    anonymous_report_claims[]
  anonymous_reports                                          anonymous_reports[]
  attachments                                                attachments[]
  bookmarks                                                  bookmarks[]
  comments                                                   comments[]
  notifications                                              notifications[]
  report_followers                                           report_followers[]
  task_completion                                            task_completions?
  report_post                                                report_posts?
  ward_happiness_events                                      ward_happiness_events[]
  assigned_department                                        officer_departments?      @relation("ReportAssignedDepartment", fields: [assigned_department_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  assigned_field_officer                                     officers?                 @relation("ReportAssignedFieldOfficer", fields: [assigned_field_officer_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users_reports_assigned_officer_idTousers                   users?                    @relation("reports_assigned_officer_idTousers", fields: [assigned_officer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ward_officers_reports_forwarding_officer_idToward_officers ward_officers?            @relation("reports_forwarding_officer_idToward_officers", fields: [forwarding_officer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  kanban_columns                                             kanban_columns?           @relation(fields: [kanban_column_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
